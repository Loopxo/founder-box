# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/apps/*/node_modules/
/packages/*/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
**/.vite/

# next.js
/.next/
/apps/web/.next/
/out/

# production
/build
/apps/mcp/dist/
/apps/mobile/.expo/
/apps/mobile/dist/
/apps/mobile/node_modules/
/packages/core/dist/
/packages/api-client/dist/
/packages/api-client/node_modules/
.founderbox/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

tweets.md
