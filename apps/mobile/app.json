{
  "expo": {
    "name": "FounderBox",
    "slug": "founderbox-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "founderbox",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.loopxo.founderbox"
    },
    "android": {
      "package": "org.loopxo.founderbox",
      "adaptiveIcon": {
        "backgroundColor": "#050506"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
