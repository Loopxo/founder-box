{
  "name": "founderbox",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <24",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "node scripts/run-with-root-env.mjs pnpm --filter web dev",
    "dev:all": "node scripts/run-with-root-env.mjs pnpm --parallel --filter web --filter mcp --filter mobile dev",
    "dev:mobile": "node scripts/run-with-root-env.mjs pnpm --filter mobile dev",
    "dev:mcp": "node scripts/run-with-root-env.mjs pnpm --filter mcp dev",
    "build": "pnpm --filter core build && pnpm --filter @founderbox/api-client build && pnpm --filter web build && pnpm --filter mcp build",
    "build:web": "pnpm --filter web build",
    "build:mcp": "pnpm --filter mcp build",
    "build:mobile:ios": "pnpm --filter mobile build:ios",
    "build:mobile:android": "pnpm --filter mobile build:android",
    "start": "node scripts/run-with-root-env.mjs pnpm --filter web start",
    "start:mcp": "node scripts/run-with-root-env.mjs pnpm --filter mcp start",
    "lint": "eslint apps packages",
    "typecheck": "pnpm --filter core typecheck && pnpm --filter @founderbox/api-client typecheck && pnpm --filter web typecheck && pnpm --filter mcp typecheck && pnpm --filter mobile typecheck",
    "test": "pnpm --filter core test && pnpm --filter @founderbox/api-client test && pnpm --filter web test && pnpm --filter @founderbox/skills test && pnpm --filter mobile test",
    "test:all": "pnpm test",
    "check:mobile": "pnpm --filter mobile typecheck && pnpm --filter mobile lint && pnpm --filter mobile test",
    "check:all": "pnpm exec prisma validate --schema prisma/schema.prisma && pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:migration-smoke": "prisma validate --schema prisma/schema.prisma",
    "mcp:smoke": "node scripts/mcp-smoke.mjs",
    "jobs:cleanup": "node scripts/run-cleanup-job.mjs",
    "jobs:reminders": "node scripts/run-daily-reminders.mjs",
    "deploy": "vercel --prod apps/web",
    "deploy:web": "vercel --prod apps/web",
    "deploy:mcp": "railway up --service founderbox-mcp",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@hookform/resolvers": "^5.2.1",
    "@modelcontextprotocol/express": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "@prisma/client": "^6.14.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sparticuz/chromium": "^141.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.2.1",
    "framer-motion": "^12.23.12",
    "jszip": "^3.10.1",
    "lucide-react": "^0.539.0",
    "next": "15.5.12",
    "next-themes": "^0.4.6",
    "prisma": "^6.14.0",
    "puppeteer-core": "^23.11.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
